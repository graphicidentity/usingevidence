<script>
(function() {
  var links = document.querySelectorAll('#primaryNav .nav-link');
  var path = location.pathname.replace(/\/?index\.html$/, '/');
  links.forEach(function(a) {
    var href = a.getAttribute('href');
    if (href && (href === path || (href !== '{{ '/' | url }}' && path.startsWith(new URL(href, location.origin).pathname)))) {
      a.classList.add('active');
      a.setAttribute('aria-current', 'page');
    }
  });
})();
</script>
